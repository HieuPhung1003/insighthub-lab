apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: <BASE64_CA_CERT>
    server: <EKS_CLUSTER_ENDPOINT>
  name: insighthub-mcp
contexts:
- context:
    cluster: insighthub-mcp
    namespace: insighthub
    user: mcp-readonly
  name: insighthub-mcp
current-context: insighthub-mcp
kind: Config
users:
- name: mcp-readonly
  user:
    token: <SA_TOKEN>
