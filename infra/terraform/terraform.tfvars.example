# InsightHub — Terraform variable overrides
# Copy to terraform.tfvars and edit as needed:
#   cp terraform.tfvars.example terraform.tfvars
#
# DO NOT commit terraform.tfvars (already in .gitignore).
# All values below are the same as variable defaults — change only what differs.

aws_region   = "ap-southeast-1"
cluster_name = "insighthub"

# ── EKS nodes ─────────────────────────────────────────────────────────────── #
node_instance_type = "t3.medium"
node_desired_size  = 2
node_min_size      = 1
node_max_size      = 4

# ── RDS ───────────────────────────────────────────────────────────────────── #
db_name            = "insighthub"
db_username        = "insighthub"
rds_instance_class = "db.t3.micro"   # smallest viable, free-tier eligible

# ── ElastiCache ───────────────────────────────────────────────────────────── #
redis_node_type = "cache.t3.micro"   # smallest viable

# ── Namespaces / IRSA ─────────────────────────────────────────────────────── #
k8s_namespace = "insighthub"
