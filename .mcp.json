{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "/home/phungminhhieu/Documents/DEVOPS_VTI/AI-for-DevOps/insighthub"
      ]
    },
    "docker": {
      "type": "http",
      "url": "http://localhost:30000",
      "headers": {
        "Authorization": "Bearer insighthub-lab-token"
      }
    },
    "kubernetes-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@0.0.62",
        "--read-only"
      ],
      "env": {
        "KUBECONFIG": "/home/phungminhhieu/.kube/mcp-viewer.kubeconfig"
      }
    },
    "prometheus": {
      "command": "npx",
      "args": [
        "-y",
        "prometheus-mcp-server@1.0.1"
      ]
    }
  }
}
